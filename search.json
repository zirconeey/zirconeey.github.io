---
layout: null
---
[
  {% assign items = site.posts | concat: site.notes %}
  {% for item in items %}
    {
      "title"    : {{ item.title | jsonify }},
      "category" : "{% if item.main_category %}{{ item.main_category }}{% elsif item.categories.size > 0 %}{{ item.categories | first }}{% else %}未分类{% endif %}",
      "url"      : "{{ site.baseurl }}{{ item.url }}",
      "date"     : "{{ item.date | date: '%Y-%m-%d' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
